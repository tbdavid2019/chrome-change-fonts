{
  "manifest_version": 3,
  "name": "Font Changer 改字體 333",
  "version": "1.3",
  "description": "Change the font family of any website. 用你喜歡的字體閱讀網站",
  "permissions": [ "activeTab", "storage","fontSettings"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "js": ["content.js"]
    }
  ]
}
